erDiagram
    PROJECT {
        string project_id PK
        string name
        string workspace_project_path
        string project_db_path
        string default_processing_profile_id
        string status
    }

    PROVIDER_CONFIG {
        string provider_config_id PK
        string provider_name
        string provider_type
        string secret_ref
        string enabled
    }

    PROCESSING_PROFILE {
        string profile_id PK
        string name
        int version
        string scope
    }

    PROJECT_METADATA {
        string project_id PK
        string project_schema_version
        string workspace_identity
    }

    BATCH {
        string batch_id PK
        string project_id
        string name
        string status
    }

    PAGE {
        string page_id PK
        string project_id
        string batch_id FK
        int page_index
        string original_artifact_id FK
        string active_cleaned_artifact_id FK
        string active_typeset_artifact_id FK
        string status
    }

    TEXT_BLOCK {
        string text_block_id PK
        string project_id
