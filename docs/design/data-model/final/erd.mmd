        string page_id FK
        int reading_order
        string active_mask_artifact_id FK
        string active_ocr_result_id FK
        string active_translation_result_id FK
        string locked_translation_result_id FK
    }

    OCR_RESULT {
        string ocr_result_id PK
        string project_id
        string text_block_id FK
        int version_number
        string source_text_hash
        string workflow_attempt_id FK
        string tool_run_id FK
    }

    TRANSLATION_RESULT {
        string translation_result_id PK
        string project_id
        string text_block_id FK
