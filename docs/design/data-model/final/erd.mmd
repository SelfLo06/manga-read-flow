        string source_ocr_result_id FK
        string source_text_hash
        string glossary_version_id FK
        string context_hash
        string workflow_attempt_id FK
        string tool_run_id FK
    }

    GLOSSARY_TERM {
        string term_id PK
        string project_id
        string source_text
        string target_text
        string status
    }

    GLOSSARY_VERSION {
        string glossary_version_id PK
        string project_id
        int version_number
        string terms_hash
        string snapshot_artifact_id FK
    }

    PROCESSING_TASK {
        string task_id PK
        string project_id
        string target_type
        string target_id
        string profile_snapshot_id FK
        string status
    }

    PROCESSING_PROFILE_SNAPSHOT {
        string profile_snapshot_id PK
        string project_id
        string source_profile_id
        int source_profile_version
        string settings_hash
    }

    WORKFLOW_ATTEMPT {
        string attempt_id PK
        string project_id
        string task_id FK
        string stage
        string target_type
        string target_id
        int attempt_number
        string status
    }

    WORKFLOW_DECISION {
        string decision_id PK
        string project_id
        string task_id FK
        string attempt_id FK
        string decision_type
        string target_type
        string target_id
    }

    WORKFLOW_DECISION_ISSUE {
        string decision_id FK
        string quality_issue_id FK
        string relation_type
    }

    QUALITY_ISSUE {
        string quality_issue_id PK
        string project_id
        string target_type
        string target_id
        string discovered_stage
        string root_stage
        string issue_type
        string status
        boolean is_blocking
    }

    PROCESSING_ARTIFACT {
        string artifact_id PK
        string project_id
        string batch_id FK
        string page_id FK
        string text_block_id FK
        string owner_type
        string owner_id
        string artifact_type
        string relative_path
        string file_hash
        string storage_state
    }

    TOOL_RUN_LOG {
        string tool_run_id PK
        string project_id
        string task_id FK
        string attempt_id FK
        string stage
        string provider_name
        string status
        string input_artifact_id FK
        string output_artifact_id FK
    }

    EXPORT_RECORD {
        string export_id PK
        string project_id
        string target_type
        string target_id
        string profile_snapshot_id FK
        string status
        string output_artifact_id FK
        string manifest_artifact_id FK
    }

