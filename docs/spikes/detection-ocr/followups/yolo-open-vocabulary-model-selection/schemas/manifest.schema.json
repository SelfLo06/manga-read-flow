{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "YOLO model-selection local manifest",
  "type": "object",
  "required": ["schema_version", "root", "samples"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "root": {"const": "."},
    "samples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sample_id", "relative_path", "version", "sha256", "width", "height", "format", "tags", "enabled"],
        "properties": {
          "sample_id": {"type": "string", "pattern": "^sample_[A-Za-z0-9_-]+$"},
          "relative_path": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\./).+"},
          "version": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "width": {"type": "integer", "minimum": 1},
          "height": {"type": "integer", "minimum": 1},
          "format": {"type": "string", "enum": ["PNG", "JPEG", "WEBP"]},
          "tags": {"type": "array", "items": {"type": "string"}},
          "enabled": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
