{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "YOLO model-selection normalized result",
  "type": "object",
  "required": ["schema_version", "run_id", "sample_id", "model", "request", "actual", "detections", "timing", "gpu", "status", "error"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "run_id": {"type": "string", "minLength": 1},
    "sample_id": {"type": "string", "pattern": "^sample_"},
    "model": {
      "type": "object",
      "required": ["family", "variant", "weight_sha256", "framework", "task_type"],
      "properties": {
        "family": {"type": "string"}, "variant": {"type": "string"}, "weight_sha256": {"type": ["string", "null"]},
        "framework": {"type": "string"}, "task_type": {"enum": ["detection", "segmentation"]}
      }
    },
    "request": {"type": "object"},
    "actual": {"type": "object"},
    "detections": {"type": "array"},
    "timing": {"type": "object"},
    "gpu": {"type": "object"},
    "status": {"enum": ["success", "empty_result", "dependency_missing", "model_load_failed", "invalid_output", "oom", "runtime_error"]},
    "error": {"type": ["object", "null"]}
  }
}
